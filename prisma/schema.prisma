datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id    String @id
  name  String
  icon  String
  color String
}

model Product {
  id            String   @id
  name          String
  description   String
  price         Float
  originalPrice Float?
  category      String
  subcategory   String?
  ref           String?
  image         String?
  isPromo       Boolean  @default(false)
  tags          String[]
}
